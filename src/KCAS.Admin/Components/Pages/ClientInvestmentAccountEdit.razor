@page "/clients/{ClientId:int}/investments/new"
@page "/clients/{ClientId:int}/investments/{AccountId:int}/edit"
@rendermode InteractiveServer
@attribute [Authorize(Policy = KcasPermissions.InvestmentsManage)]
@using System.ComponentModel.DataAnnotations
@using KCAS.Admin.Data
@inject ClientOperationsService ClientOperations
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>@(AccountId is null ? "New investment account" : "Edit investment account")</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Investment workflow</p>
        <h1>@(AccountId is null ? "New investment account" : "Edit investment account")</h1>
    </div>
    <a class="btn btn-outline-secondary" href="@($"/clients/{ClientId}#investments")">Cancel</a>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-warning">@statusMessage</div>
}

<EditForm Model="model" OnValidSubmit="SaveAsync" FormName="investment-account-edit">
    <section class="detail-grid">
        <article class="detail-panel form-panel">
            <h2>Account</h2>
            <label>Administrator <input class="form-control" @bind="model.Administrator" list="investment-administrators" /></label>
            <datalist id="investment-administrators">
                @foreach (var option in ReferenceValues(referenceOptions.Administrators, model.Administrator))
                {
                    <option value="@option"></option>
                }
            </datalist>
            <label>Account number <InputText class="form-control" @bind-Value="model.AccountNumber" /></label>
            <label>Investment date <InputDate class="form-control" @bind-Value="model.InvestmentDate" /></label>
            <label>Surrender date <InputDate class="form-control" @bind-Value="model.SurrenderDate" /></label>
        </article>
        <article class="detail-panel form-panel">
            <h2>Product</h2>
            <label>Product <InputText class="form-control" @bind-Value="model.ProductName" /></label>
            <label>Product type <input class="form-control" @bind="model.ProductType" list="investment-product-types" /></label>
            <datalist id="investment-product-types">
                @foreach (var option in ReferenceValues(referenceOptions.ProductTypes, model.ProductType))
                {
                    <option value="@option"></option>
                }
            </datalist>
            <label>Fund <input class="form-control" @bind="model.FundName" list="investment-funds" /></label>
            <datalist id="investment-funds">
                @foreach (var option in ReferenceValues(referenceOptions.Funds, model.FundName))
                {
                    <option value="@option"></option>
                }
            </datalist>
            <label class="check-row"><InputCheckbox @bind-Value="model.IsLinkedHead" /> Linked head account</label>
            <label class="check-row"><InputCheckbox @bind-Value="model.IsFinal" /> Final</label>
        </article>
    </section>

    <div class="form-actions">
        <button class="btn btn-primary" type="submit">Save account</button>
        <a class="btn btn-outline-secondary" href="@($"/clients/{ClientId}#investments")">Cancel</a>
    </div>
</EditForm>

@code {
    [Parameter]
    public int ClientId { get; set; }

    [Parameter]
    public int? AccountId { get; set; }

    private ClientInvestmentAccountEditModel model = new();
    private InvestmentReferenceOptionsModel referenceOptions = new([], [], []);
    private string? statusMessage;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            model = await ClientOperations.LoadInvestmentAccountAsync(ClientId, AccountId);
            referenceOptions = await ClientOperations.LoadInvestmentReferenceOptionsAsync();
        }
        catch (InvalidOperationException ex)
        {
            statusMessage = ex.Message;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            await ClientOperations.SaveInvestmentAccountAsync(model, authState.User.Identity?.Name);
            Navigation.NavigateTo($"/clients/{ClientId}#investments");
        }
        catch (ValidationException ex)
        {
            statusMessage = ex.Message;
        }
        catch (InvalidOperationException ex)
        {
            statusMessage = ex.Message;
        }
    }

    private static IEnumerable<string> ReferenceValues(IEnumerable<string> values, string? currentValue)
    {
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        if (!string.IsNullOrWhiteSpace(currentValue) && seen.Add(currentValue.Trim()))
        {
            yield return currentValue.Trim();
        }

        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value) && seen.Add(value.Trim()))
            {
                yield return value.Trim();
            }
        }
    }
}
