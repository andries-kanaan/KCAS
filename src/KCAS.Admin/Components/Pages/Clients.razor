@page "/clients"
@rendermode InteractiveServer
@attribute [Authorize(Policy = KcasPermissions.ClientsView)]
@using KCAS.Admin.Data
@inject ClientSearchService ClientSearch

<PageTitle>Clients</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Client register</p>
        <h1>Clients</h1>
    </div>
</div>

@if (clients.Count == 0)
{
    <section class="empty-state">
        <h2>No clients found</h2>
        <p>Adjust the column filters or import legacy clients with the console importer.</p>
    </section>
}

<div class="table-responsive">
    <table class="table align-middle filter-table">
        <thead>
            <tr>
                <th>
                    <button class="sort-header" type="button" @onclick="@(() => SortByAsync("kanaanId"))">
                        Kanaan ID @SortIndicator("kanaanId")
                    </button>
                </th>
                <th>
                    <button class="sort-header" type="button" @onclick="@(() => SortByAsync("name"))">
                        Name @SortIndicator("name")
                    </button>
                </th>
                <th>
                    <button class="sort-header" type="button" @onclick="@(() => SortByAsync("surname"))">
                        Surname @SortIndicator("surname")
                    </button>
                </th>
                <th>
                    <button class="sort-header" type="button" @onclick="@(() => SortByAsync("email"))">
                        Primary email @SortIndicator("email")
                    </button>
                </th>
                <th>
                    <button class="sort-header" type="button" @onclick="@(() => SortByAsync("phone"))">
                        Primary phone @SortIndicator("phone")
                    </button>
                </th>
                <th>
                    <button class="sort-header" type="button" @onclick="@(() => SortByAsync("status"))">
                        Status @SortIndicator("status")
                    </button>
                </th>
            </tr>
            <tr class="filter-row">
                <th>
                    <input class="form-control form-control-sm" value="@kanaanIdFilter" @oninput="@(args => FilterChangedAsync(args, value => kanaanIdFilter = value))" aria-label="Filter by Kanaan ID" />
                </th>
                <th>
                    <input class="form-control form-control-sm" value="@nameFilter" @oninput="@(args => FilterChangedAsync(args, value => nameFilter = value))" aria-label="Filter by name" />
                </th>
                <th>
                    <input class="form-control form-control-sm" value="@surnameFilter" @oninput="@(args => FilterChangedAsync(args, value => surnameFilter = value))" aria-label="Filter by surname" />
                </th>
                <th>
                    <input class="form-control form-control-sm" value="@emailFilter" @oninput="@(args => FilterChangedAsync(args, value => emailFilter = value))" aria-label="Filter by email" />
                </th>
                <th>
                    <input class="form-control form-control-sm" value="@phoneFilter" @oninput="@(args => FilterChangedAsync(args, value => phoneFilter = value))" aria-label="Filter by phone" />
                </th>
                <th>
                    <input class="form-control form-control-sm" value="@statusFilter" @oninput="@(args => FilterChangedAsync(args, value => statusFilter = value))" aria-label="Filter by status" placeholder="Active" />
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in clients)
            {
                <tr>
                    <td>@client.KanaanId</td>
                    <td>
                        <a href="@($"/clients/{client.Id}")">@client.Name</a>
                    </td>
                    <td>@client.Surname</td>
                    <td>@client.PrimaryEmail</td>
                    <td>@client.PrimaryPhone</td>
                    <td>@(client.IsActive ? "Active" : "Inactive")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private string? kanaanIdFilter;
    private string? nameFilter;
    private string? surnameFilter;
    private string? emailFilter;
    private string? phoneFilter;
    private string? statusFilter;
    private string sortColumn = "name";
    private bool sortDescending;
    private List<ClientSearchResult> clients = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadClientsAsync();
    }

    private async Task FilterChangedAsync(ChangeEventArgs args, Action<string?> setValue)
    {
        setValue(args.Value?.ToString());
        await LoadClientsAsync();
    }

    private async Task SortByAsync(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
        }
        else
        {
            sortColumn = column;
            sortDescending = false;
        }

        await LoadClientsAsync();
    }

    private async Task LoadClientsAsync()
    {
        clients = await ClientSearch.SearchAsync(new ClientSearchRequest(
            KanaanId: kanaanIdFilter,
            Name: nameFilter,
            Surname: surnameFilter,
            Email: emailFilter,
            Phone: phoneFilter,
            Status: statusFilter,
            SortColumn: sortColumn,
            SortDescending: sortDescending));
    }

    private string SortIndicator(string column)
    {
        if (sortColumn != column)
        {
            return string.Empty;
        }

        return sortDescending ? "down" : "up";
    }
}
