@page "/clients"
@using Microsoft.EntityFrameworkCore
@using KCAS.Admin.Data
@inject ApplicationDbContext Db

<PageTitle>Clients</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Client register</p>
        <h1>Clients</h1>
    </div>
</div>

@if (clients.Count == 0)
{
    <section class="empty-state">
        <h2>No clients yet</h2>
        <p>The MySQL table is ready. Client import and redesigned capture screens can be added once the Yii1 workflows are reviewed.</p>
    </section>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in clients)
                {
                    <tr>
                        <td>@client.ClientCode</td>
                        <td>@client.FirstName @client.LastName</td>
                        <td>@client.Email</td>
                        <td>@client.MobileNumber</td>
                        <td>@(client.IsActive ? "Active" : "Inactive")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<Client> clients = [];

    protected override async Task OnInitializedAsync()
    {
        clients = await Db.Clients
            .OrderBy(client => client.LastName)
            .ThenBy(client => client.FirstName)
            .Take(100)
            .ToListAsync();
    }
}
