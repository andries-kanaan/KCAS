@page "/"
@using Microsoft.EntityFrameworkCore
@using KCAS.Admin.Data
@inject ApplicationDbContext Db

<PageTitle>KCAS Admin</PageTitle>

<section class="landing-hero">
    <div>
        <img class="hero-brand" src="images/kanaan-header.jpg" alt="Kanaan Asset Managers" />
        <p class="eyebrow">Kanaan Client Administration System</p>
        <h2>Kanaan Client Administration System</h2>
        <p>Use this workspace as the new KCAS foundation while client records, identity, and compliance workflows move across from the legacy system.</p>
        <div class="hero-actions">
            <a class="button-primary" href="clients">Open clients</a>
            <a class="button-secondary" href="Account/Login">Sign in</a>
        </div>
    </div>
</section>

<div class="page-header">
    <div>
        <p class="eyebrow">Workspace status</p>
        <h1>Today at a glance</h1>
        <p class="lede">Core services are connected to the MySQL-backed KCAS schema and ready for the next workflow screens.</p>
    </div>
</div>

<section class="metric-grid">
    <div class="metric-card">
        <span class="metric-label">Clients</span>
        <strong>@clientCount</strong>
    </div>
    <div class="metric-card">
        <span class="metric-label">Active clients</span>
        <strong>@activeClientCount</strong>
    </div>
    <div class="metric-card">
        <span class="metric-label">Database</span>
        <strong>@databaseStatus</strong>
    </div>
</section>

<section class="work-area">
    <h2>Foundation areas</h2>
    <div class="workspace-grid">
        <div>
            <h3>Client records</h3>
            <p>Start from a clean Blazor and MySQL-backed client register before importing and redesigning the Yii1 functionality.</p>
        </div>
        <div>
            <h3>Identity</h3>
            <p>ASP.NET Core Identity is enabled for user registration, login, account management, and future role-based access control.</p>
        </div>
        <div>
            <h3>Compliance foundation</h3>
            <p>The first schema keeps personal information explicit so POPIA, FICA, and audit requirements can be added deliberately.</p>
        </div>
    </div>
</section>

@code {
    private int clientCount;
    private int activeClientCount;
    private string databaseStatus = "Pending";

    protected override async Task OnInitializedAsync()
    {
        clientCount = await Db.Clients.CountAsync();
        activeClientCount = await Db.Clients.CountAsync(client => client.IsActive);
        databaseStatus = "Online";
    }
}
