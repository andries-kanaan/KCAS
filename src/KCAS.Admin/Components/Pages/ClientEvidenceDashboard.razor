@page "/compliance/client-evidence"
@page "/compliance/client-evidence/scan"
@rendermode InteractiveServer
@attribute [Authorize(Policy = KcasPermissions.ComplianceView)]
@using KCAS.Admin.Data
@implements IDisposable
@inject ClientEvidenceReadinessService EvidenceService
@inject ClientEvidenceScanCoordinator ScanCoordinator
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Client evidence readiness</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Compliance administration</p>
        <h1>Client evidence readiness</h1>
        <p class="lede">Scan server-side client folders, link evidence and track readiness for client risk assessment.</p>
    </div>
    <a class="btn btn-outline-secondary" href="/compliance">Compliance dashboard</a>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-info">@statusMessage</div>
}

@if (model is null)
{
    <p>Loading client evidence readiness...</p>
}
else
{
    <section class="summary-grid">
        <article class="summary-card">
            <span>Requirements</span>
            <strong>@model.RequirementCount</strong>
        </article>
        <article class="summary-card">
            <span>Ready clients</span>
            <strong>@model.ReadyClientCount</strong>
        </article>
        <article class="summary-card">
            <span>Blocked clients</span>
            <strong>@model.BlockedClientCount</strong>
        </article>
        <article class="summary-card">
            <span>Review files</span>
            <strong>@model.UnmatchedFiles.Count</strong>
        </article>
    </section>

    <section class="work-area">
        <h2>Server document scan</h2>
        <p class="text-muted">Use a server path that the live KCAS process can read. KCAS links metadata and paths; it does not copy client documents.</p>
        <div class="workspace-grid">
            <input class="form-control" @bind="scanRootPath" placeholder="Server client document root path" disabled="@(!canManage)" />
            <input class="form-control" @bind="reason" placeholder="Required reason" disabled="@(!canManage)" />
        </div>
        <div class="row-actions mt-2">
            <button type="button" class="btn btn-outline-secondary" @onclick="OpenFolderPicker" disabled="@(!canManage)">Browse folders</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="SaveRootAsync" disabled="@(!canManage)">Save root</button>
            <button type="button" class="btn btn-primary" @onclick="RunScanAsync" disabled="@(!canManage || IsScanRunning)">Run scan</button>
            @if (CanCancelScan)
            {
                <button type="button" class="btn btn-outline-danger" @onclick="CancelScanAsync">Cancel scan</button>
            }
        </div>
        <ServerFolderPicker IsOpen="@isFolderPickerOpen"
                            InitialPath="@scanRootPath"
                            Disabled="@(!canManage)"
                            Title="Choose scan root folder"
                            Selected="SelectFolder"
                            Closed="CloseFolderPicker" />
        @if (model.LatestScanRun is not null)
        {
            @if (IsScanRunning)
            {
                <div class="scan-progress mt-3">
                    <div class="scan-progress-header">
                        <strong>@(model.LatestScanRun.Status == ClientEvidenceScanStatuses.Cancelling ? "Cancelling scan..." : "Scanning server documents...")</strong>
                        <span>@model.LatestScanRun.TotalFiles file(s) processed</span>
                    </div>
                    <div class="progress" role="progressbar" aria-label="Evidence scan progress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                    </div>
                    <div class="scan-progress-counts">
                        <span>@model.LatestScanRun.LinkedFiles linked</span>
                        <span>@model.LatestScanRun.UnmatchedFiles unmatched</span>
                        <span>@model.LatestScanRun.AmbiguousFiles ambiguous</span>
                        <span>@model.LatestScanRun.SkippedFiles skipped</span>
                    </div>
                </div>
            }
            <div class="table-responsive mt-3">
                <table class="table align-middle">
                    <tbody>
                        <tr><th>Latest run</th><td>@model.LatestScanRun.StartedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td></tr>
                        <tr><th>Status</th><td>@model.LatestScanRun.Status</td></tr>
                        <tr><th>Root</th><td>@model.LatestScanRun.RootPath</td></tr>
                        <tr><th>Totals</th><td>@model.LatestScanRun.TotalFiles file(s), @model.LatestScanRun.LinkedFiles linked, @model.LatestScanRun.UnmatchedFiles unmatched, @model.LatestScanRun.AmbiguousFiles ambiguous, @model.LatestScanRun.SkippedFiles skipped</td></tr>
                        @if (!string.IsNullOrWhiteSpace(model.LatestScanRun.ErrorMessage))
                        {
                            <tr><th>Error</th><td>@model.LatestScanRun.ErrorMessage</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="work-area">
        <h2>Client readiness</h2>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Category</th>
                        <th>Kanaan ID</th>
                        <th>Complete</th>
                        <th>Exceptions</th>
                        <th>Blocked</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var client in model.Clients)
                    {
                        <tr>
                            <td>@client.DisplayName</td>
                            <td>@client.ClientCategory</td>
                            <td>@Display(client.KanaanId)</td>
                            <td>@client.CompleteCount / @client.RequiredCount</td>
                            <td>@client.ExceptionCount</td>
                            <td>@client.BlockedCount</td>
                            <td>@(client.IsReadyForRiskAssessment ? "Ready" : "Blocked")</td>
                            <td class="text-end"><a class="btn btn-outline-secondary btn-sm" href="@($"/clients/{client.ClientId}/evidence")">Open</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="work-area">
        <h2>Unmatched or ambiguous scan files</h2>
        @if (model.UnmatchedFiles.Count == 0)
        {
            <p class="text-muted">No unmatched or ambiguous files in the latest scan data.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead><tr><th>File</th><th>Status</th><th>Suggested type</th><th>Reason</th></tr></thead>
                    <tbody>
                        @foreach (var file in model.UnmatchedFiles)
                        {
                            <tr>
                                <td>@file.RelativePath</td>
                                <td>@file.MatchStatus</td>
                                <td>@Display(file.SuggestedEvidenceType)</td>
                                <td>@Display(file.MatchReason)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

@code {
    private ClientEvidenceDashboardModel? model;
    private string? scanRootPath;
    private string? reason;
    private string? currentUser;
    private bool canManage;
    private string? statusMessage;
    private bool isFolderPickerOpen;
    private CancellationTokenSource? pollingCancellation;

    private bool IsScanRunning => model?.LatestScanRun?.Status is ClientEvidenceScanStatuses.Running or ClientEvidenceScanStatuses.Cancelling;

    private bool CanCancelScan => canManage && model?.LatestScanRun?.Status == ClientEvidenceScanStatuses.Running;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        currentUser = authState.User.Identity?.Name;
        canManage = authState.User.HasClaim(KcasClaimTypes.Permission, KcasPermissions.ComplianceManage);
        await LoadAsync();
        if (IsScanRunning)
        {
            StartPolling();
        }
    }

    private async Task LoadAsync()
    {
        model = await EvidenceService.LoadDashboardAsync();
        scanRootPath = model.ScanRootPath ?? scanRootPath;
    }

    private async Task SaveRootAsync() => await ExecuteAsync(async () => await EvidenceService.SaveScanRootAsync(scanRootPath ?? "", currentUser, reason ?? ""));

    private async Task RunScanAsync()
    {
        try
        {
            var runId = await ScanCoordinator.StartScanAsync(scanRootPath, currentUser, reason ?? "");
            statusMessage = $"Evidence scan {runId} started.";
            await LoadAsync();
            StartPolling();
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
    }

    private async Task CancelScanAsync()
    {
        if (model?.LatestScanRun is null)
        {
            return;
        }

        try
        {
            await ScanCoordinator.CancelScanAsync(model.LatestScanRun.Id, currentUser, reason ?? "");
            statusMessage = "Evidence scan cancellation requested.";
            await LoadAsync();
            StartPolling();
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
    }

    private void SelectFolder(string path) => scanRootPath = path;

    private void OpenFolderPicker() => isFolderPickerOpen = true;

    private void CloseFolderPicker() => isFolderPickerOpen = false;

    private void StartPolling()
    {
        pollingCancellation?.Cancel();
        pollingCancellation?.Dispose();
        pollingCancellation = new CancellationTokenSource();
        _ = PollLatestRunAsync(pollingCancellation.Token);
    }

    private async Task PollLatestRunAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await LoadAsync();
                    StateHasChanged();
                    if (!IsScanRunning)
                    {
                        pollingCancellation?.Cancel();
                    }
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        try
        {
            await action();
            statusMessage = "Client evidence readiness updated.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
    }

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;

    public void Dispose()
    {
        pollingCancellation?.Cancel();
        pollingCancellation?.Dispose();
    }
}
