@page "/imports"
@page "/imports/{RunId:long}"
@rendermode InteractiveServer
@implements IAsyncDisposable
@attribute [Authorize(Policy = KcasPermissions.LegacyImportsView)]
@using KCAS.Admin.Data
@using KCAS.Admin.LegacyImport
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject ApplicationDbContext Db
@inject LegacyImportWebService ImportService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAuthorizationService AuthorizationService

<PageTitle>Legacy import reconciliation</PageTitle>

<div class="page-header">
    <div>
        <p class="eyebrow">Administration</p>
        <h1>Legacy import reconciliation</h1>
        <p class="lede">Review what is new, unchanged, changed, missing, or invalid before any existing KCAS data is altered.</p>
    </div>
</div>

<section class="work-area">
    <div class="section-heading-row">
        <div>
            <h2>Import SQL export</h2>
            <p class="section-subtitle">Upload a fresh kanaanclients SQL export to stage, scan and reconcile it from KCAS.</p>
        </div>
    </div>
    <div class="import-mode-grid">
        <label class="check-row">
            <input class="form-check-input" type="radio" name="import-mode" checked="@IsIncrementalMode" @onchange="@(() => importMode = ImportModeIncremental)" disabled="@isBusy" />
            <span>Incremental reconciliation</span>
        </label>
        <label class="check-row">
            <input class="form-check-input" type="radio" name="import-mode" checked="@(!IsIncrementalMode)" @onchange="@(() => importMode = ImportModeLegacyBaseline)" disabled="@(isBusy || !CanBaselineImport)" />
            <span>Baseline import</span>
        </label>
    </div>
    <div class="import-grid">
        <label>
            SQL export
            <InputFile class="form-control" OnChange="SelectUpload" accept=".sql" disabled="@isBusy" />
            @if (uploadFile is not null)
            {
                <span class="muted">@uploadFile.Name (@FormatBytes(uploadFile.Size))</span>
            }
        </label>
        @if (IsIncrementalMode)
        {
            <label>
                Table scope
                <select class="form-select" @bind="selectedTableScope" disabled="@isBusy">
                    @foreach (var option in LegacyImportTableScopes.Options)
                    {
                        <option value="@option.Value">@option.Label</option>
                    }
                </select>
            </label>
            <label class="check-row">
            <input class="form-check-input" type="checkbox" @bind="applyAllAfterScan" disabled="@isBusy" />
            <span>After scan, apply all eligible new records</span>
            </label>
        }
        else
        {
            <p class="section-subtitle">Backs up KCAS, clears previous imported baseline and compliance operational review/scan history, then imports the mapped baseline again.</p>
        }
        <div class="form-actions">
            <button type="button" class="btn btn-primary" @onclick="UploadAndScanAsync" disabled="@(isBusy || uploadFile is null)">
                @(isBusy ? "Working..." : IsIncrementalMode ? "Upload and scan" : "Reset and import baseline")
            </button>
        </div>
    </div>
    @if (!ImportService.CanResetImportedLegacyData)
    {
        <p class="muted mt-2">Legacy baseline import is disabled in this environment.</p>
    }
    @if (activeJob is not null)
    {
        <div class="import-progress" role="status" aria-live="polite">
            <div class="progress" aria-label="@activeJob.Message">
                <div class="progress-bar progress-bar-striped @(activeJob.IsRunning ? "progress-bar-animated" : string.Empty)" style="width: @(activeJob.Percent)%"></div>
            </div>
            <p class="muted">@activeJob.Title: @activeJob.Message (@activeJob.Percent%)</p>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-success mt-3">@statusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }
</section>

@if (runs.Count == 0)
{
    <section class="work-area">
        <p>No reconciliation scans have been recorded.</p>
    </section>
}
else
{
    <section class="work-area">
        <div class="filter-grid">
            <label>
                Import run
                <select class="form-select" value="@selectedRunId" @onchange="SelectRunAsync">
                    @foreach (var item in runs)
                    {
                        <option value="@item.Id">#@item.Id — @item.StartedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm") — @item.Mode — @item.Status</option>
                    }
                </select>
            </label>
            <label>
                Classification
                <select class="form-select" value="@classification" @onchange="FilterClassificationAsync">
                    <option value="">All</option>
                    @foreach (var value in classifications)
                    {
                        <option value="@value">@value</option>
                    }
                </select>
            </label>
            <label>
                Source table
                <select class="form-select" value="@sourceTable" @onchange="FilterTableAsync">
                    <option value="">All</option>
                    @foreach (var value in sourceTables)
                    {
                        <option value="@value">@value</option>
                    }
                </select>
            </label>
        </div>
    </section>

    @if (selectedRun is not null)
    {
        <section class="detail-panel">
            <div class="section-heading-row">
                <div>
                    <h2>Run #@selectedRun.Id</h2>
                    <p class="section-subtitle">@selectedRun.Mode · @selectedRun.Status</p>
                </div>
                @if (CanApplySelectedRun)
                {
                    <button type="button" class="btn btn-primary" @onclick="ApplyAllAsync" disabled="@isBusy">
                        @(isBusy ? "Working..." : $"Apply all eligible new records ({eligibleNewCount})")
                    </button>
                }
            </div>
            <p>
                New @selectedRun.NewCount · Applied @selectedRun.AppliedCount · Unchanged @selectedRun.UnchangedCount ·
                Changed @selectedRun.ChangedCount · Missing @selectedRun.MissingCount · Invalid @selectedRun.InvalidCount ·
                Orphaned @selectedRun.OrphanedCount · Failed @selectedRun.FailedCount
            </p>
            <p class="text-muted mb-1">Source database: @selectedRun.SourceLabel · Snapshot SHA-256: @ShortHash(selectedRun.SourceSnapshotSha256)</p>
            <p class="text-muted">Fund valuations and KYC policies are review-only where legacy replacement workflows create new primary IDs.</p>
            @if (selectedRun.ApprovedScanRunId.HasValue)
            {
                <p class="text-muted">Approved scan: #@selectedRun.ApprovedScanRunId</p>
            }
            @if (!string.IsNullOrWhiteSpace(selectedRun.ErrorSummary))
            {
                <div class="alert alert-danger">@selectedRun.ErrorSummary</div>
            }
        </section>
    }

    <section class="detail-panel">
        <h2>Reconciliation items</h2>
        <p class="text-muted">Showing at most 200 rows. Changed and missing rows are analysis items only; they have not been merged or deleted.</p>
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Table</th>
                        <th>Legacy ID</th>
                        <th>Classification</th>
                        <th>Apply state</th>
                        <th>Differences</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr>
                            <td>@row.SourceTable</td>
                            <td>@row.SourceId</td>
                            <td><span class="badge text-bg-secondary">@row.Classification</span></td>
                            <td>@row.ApplyStatus</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(row.Error))
                                {
                                    <p class="mb-1 text-danger">@row.Error</p>
                                }
                                @if (row.Differences.Count == 0)
                                {
                                    <span>—</span>
                                }
                                else
                                {
                                    <details>
                                        <summary>@row.Differences.Count field(s)</summary>
                                        <div class="table-responsive mt-2">
                                            <table class="table table-sm">
                                                <thead><tr><th>Field</th><th>Previous source</th><th>Incoming source</th><th>Decision</th></tr></thead>
                                                <tbody>
                                                    @foreach (var difference in row.Differences.OrderBy(item => item.FieldName))
                                                    {
                                                        <tr>
                                                            <td>@difference.FieldName</td>
                                                            <td class="preserve-lines">@Display(difference.BaselineValue)</td>
                                                            <td class="preserve-lines">@Display(difference.IncomingValue)</td>
                                                            <td>@difference.Decision</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </details>
                                }
                                @if (ImportService.CanResolveReview(row))
                                {
                                    <details class="mt-2">
                                        <summary>Review payloads</summary>
                                        <div class="review-payload-grid mt-2">
                                            <div>
                                                <strong>Baseline source</strong>
                                                <pre>@Display(row.BaselinePayloadJson)</pre>
                                            </div>
                                            <div>
                                                <strong>Incoming source</strong>
                                                <pre>@Display(row.IncomingPayloadJson)</pre>
                                            </div>
                                            <div>
                                                <strong>Current KCAS</strong>
                                                <pre>@Display(currentKcasPayloads.GetValueOrDefault(row.Id))</pre>
                                            </div>
                                        </div>
                                    </details>
                                }
                            </td>
                            <td>
                                @if (ImportService.IsEligibleForApply(row) && selectedRun is not null && selectedRun.Mode == LegacyImportModes.Scan && canApplyImports)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ApplyRowAsync(row)" disabled="@isBusy">
                                        Apply
                                    </button>
                                }
                                else if (ImportService.CanResolveReview(row) && canReviewImports)
                                {
                                    <div class="review-actions">
                                        <textarea class="form-control form-control-sm" rows="2" placeholder="Review reason" value="@ReviewReason(row.Id)" @onchange="args => SetReviewReason(row.Id, args.Value?.ToString())" disabled="@isBusy"></textarea>
                                        @if (row.Classification == LegacyImportClassifications.Changed)
                                        {
                                            <textarea class="form-control form-control-sm" rows="2" placeholder="Manual resolution value or note" value="@ManualValue(row.Id)" @onchange="args => SetManualValue(row.Id, args.Value?.ToString())" disabled="@isBusy"></textarea>
                                        }
                                        <div class="btn-group btn-group-sm flex-wrap" role="group" aria-label="Review row actions">
                                            @if (ImportService.CanRetainKcas(row))
                                            {
                                                @if (canApplyImports && ImportService.CanApplyIncomingLegacy(row))
                                                {
                                                    <button type="button" class="btn btn-outline-primary" @onclick="() => ApplyIncomingLegacyAsync(row)" disabled="@isBusy">
                                                        Apply incoming
                                                    </button>
                                                }
                                                <button type="button" class="btn btn-outline-secondary" @onclick="() => RetainKcasAsync(row)" disabled="@isBusy">
                                                    Retain KCAS
                                                </button>
                                                <button type="button" class="btn btn-outline-secondary" @onclick="() => ManualResolveAsync(row)" disabled="@isBusy">
                                                    Manual
                                                </button>
                                            }
                                            <button type="button" class="btn btn-outline-secondary" @onclick="() => DeferReviewAsync(row)" disabled="@isBusy">
                                                Defer
                                            </button>
                                            <button type="button" class="btn btn-outline-danger" @onclick="() => RejectReviewAsync(row)" disabled="@isBusy">
                                                Reject
                                            </button>
                                        </div>
                                    </div>
                                }
                                else if (LegacyImportApprovalValidator.ReviewOnlySourceTables.Contains(row.SourceTable) && row.Classification == LegacyImportClassifications.New)
                                {
                                    <span class="text-muted">Review only</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    [Parameter] public long? RunId { get; set; }

    private readonly string[] classifications =
    [
        LegacyImportClassifications.New,
        LegacyImportClassifications.Unchanged,
        LegacyImportClassifications.Changed,
        LegacyImportClassifications.MissingFromSource,
        LegacyImportClassifications.Invalid,
        LegacyImportClassifications.Orphaned
    ];
    private List<LegacyImportRun> runs = [];
    private List<LegacyImportRowState> rows = [];
    private List<string> sourceTables = [];
    private IReadOnlyDictionary<long, string?> currentKcasPayloads = new Dictionary<long, string?>();
    private readonly Dictionary<long, string> reviewReasons = [];
    private readonly Dictionary<long, string> manualValues = [];
    private LegacyImportRun? selectedRun;
    private long selectedRunId;
    private string classification = LegacyImportClassifications.Changed;
    private string sourceTable = string.Empty;
    private IBrowserFile? uploadFile;
    private const string ImportModeIncremental = "Incremental";
    private const string ImportModeLegacyBaseline = "LegacyBaseline";
    private string importMode = ImportModeIncremental;
    private string selectedTableScope = LegacyImportTableScopes.AllMapped;
    private bool applyAllAfterScan;
    private bool isBusy;
    private LegacyImportJobSnapshot? activeJob;
    private CancellationTokenSource? pollingCancellation;
    private string? statusMessage;
    private string? errorMessage;
    private int eligibleNewCount;
    private bool canReviewImports;
    private bool canApplyImports;

    private bool CanApplySelectedRun =>
        selectedRun is { Mode: LegacyImportModes.Scan, CompletedAtUtc: not null } &&
        selectedRun.Status is LegacyImportRunStatuses.Completed or LegacyImportRunStatuses.AwaitingReview &&
        canApplyImports &&
        eligibleNewCount > 0;

    private bool IsIncrementalMode => importMode == ImportModeIncremental;
    private bool CanBaselineImport => ImportService.CanResetImportedLegacyData;

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        canReviewImports = (await AuthorizationService.AuthorizeAsync(authState.User, KcasPermissions.LegacyImportsReview)).Succeeded;
        canApplyImports = (await AuthorizationService.AuthorizeAsync(authState.User, KcasPermissions.LegacyImportsApply)).Succeeded;
        runs = await Db.LegacyImportRuns.AsNoTracking().OrderByDescending(run => run.Id).Take(20).ToListAsync();
        selectedRunId = RunId.HasValue && runs.Any(run => run.Id == RunId.Value) ? RunId.Value : runs.FirstOrDefault()?.Id ?? 0;
        await LoadRowsAsync();
    }

    private async Task LoadRowsAsync()
    {
        selectedRun = runs.SingleOrDefault(run => run.Id == selectedRunId);
        if (selectedRun is null)
        {
            rows = [];
            sourceTables = [];
            currentKcasPayloads = new Dictionary<long, string?>();
            eligibleNewCount = 0;
            return;
        }

        sourceTables = await Db.LegacyImportRowStates.AsNoTracking()
            .Where(row => row.LegacyImportRunId == selectedRunId)
            .Select(row => row.SourceTable)
            .Distinct()
            .OrderBy(value => value)
            .ToListAsync();

        eligibleNewCount = await Db.LegacyImportRowStates.AsNoTracking()
            .Where(row => row.LegacyImportRunId == selectedRunId)
            .Where(row => row.Classification == LegacyImportClassifications.New)
            .Where(row => row.ApplyStatus != LegacyImportApplyStatuses.Applied)
            .Where(row => row.SourceTable != "tbl_fund" && row.SourceTable != "tbl_kyc")
            .CountAsync();

        var query = Db.LegacyImportRowStates.AsNoTracking()
            .Include(row => row.Differences)
            .Where(row => row.LegacyImportRunId == selectedRunId);
        if (!string.IsNullOrWhiteSpace(classification))
        {
            query = query.Where(row => row.Classification == classification);
        }
        if (!string.IsNullOrWhiteSpace(sourceTable))
        {
            query = query.Where(row => row.SourceTable == sourceTable);
        }
        rows = await query.OrderBy(row => row.SourceTable).ThenBy(row => row.SourceId).Take(200).ToListAsync();
        currentKcasPayloads = await ImportService.GetCurrentKcasPayloadsAsync(rows.Select(row => row.Id));
    }

    private void SelectUpload(InputFileChangeEventArgs args)
    {
        uploadFile = args.File;
        statusMessage = null;
        errorMessage = null;
    }

    private async Task UploadAndScanAsync()
    {
        if (uploadFile is null)
        {
            return;
        }

        await StartJobAsync(async () => await ImportService.StartScanUploadedSqlJobAsync(
            uploadFile,
            applyAllAfterScan,
            resetImportedDataFirst: !IsIncrementalMode,
            IsIncrementalMode ? selectedTableScope : LegacyImportTableScopes.AllMapped));
    }

    private async Task ApplyAllAsync()
    {
        if (selectedRun is null)
        {
            return;
        }

        await StartJobAsync(async () => await ImportService.StartApplyAllNewRowsJobAsync(selectedRun.Id, selectedTableScope));
    }

    private async Task ApplyRowAsync(LegacyImportRowState row)
    {
        if (selectedRun is null)
        {
            return;
        }

        await StartJobAsync(async () => await ImportService.StartApplySingleNewRowJobAsync(selectedRun.Id, row.SourceTable, row.SourceId, selectedTableScope));
    }

    private async Task RetainKcasAsync(LegacyImportRowState row)
    {
        isBusy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var reviewedBy = authState.User.Identity?.Name ?? "KCAS user";
            await ImportService.RetainKcasForChangedRowAsync(row.Id, reviewedBy, ReviewReason(row.Id));
            statusMessage = $"{row.SourceTable} #{row.SourceId}: KCAS values retained.";
            runs = await Db.LegacyImportRuns.AsNoTracking().OrderByDescending(run => run.Id).Take(20).ToListAsync();
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ApplyIncomingLegacyAsync(LegacyImportRowState row)
    {
        isBusy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var reviewedBy = authState.User.Identity?.Name ?? "KCAS user";
            await ImportService.ApplyIncomingLegacyForChangedRowAsync(row.Id, reviewedBy, ReviewReason(row.Id));
            statusMessage = $"{row.SourceTable} #{row.SourceId}: incoming legacy values applied.";
            runs = await Db.LegacyImportRuns.AsNoTracking().OrderByDescending(run => run.Id).Take(20).ToListAsync();
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ManualResolveAsync(LegacyImportRowState row)
    {
        isBusy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var reviewedBy = authState.User.Identity?.Name ?? "KCAS user";
            await ImportService.RecordManualResolutionAsync(row.Id, reviewedBy, ManualValue(row.Id), ReviewReason(row.Id));
            statusMessage = $"{row.SourceTable} #{row.SourceId}: manual resolution recorded.";
            runs = await Db.LegacyImportRuns.AsNoTracking().OrderByDescending(run => run.Id).Take(20).ToListAsync();
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeferReviewAsync(LegacyImportRowState row)
    {
        isBusy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var reviewedBy = authState.User.Identity?.Name ?? "KCAS user";
            await ImportService.DeferReviewAsync(row.Id, reviewedBy, ReviewReason(row.Id));
            statusMessage = $"{row.SourceTable} #{row.SourceId}: review deferred.";
            runs = await Db.LegacyImportRuns.AsNoTracking().OrderByDescending(run => run.Id).Take(20).ToListAsync();
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RejectReviewAsync(LegacyImportRowState row)
    {
        isBusy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var reviewedBy = authState.User.Identity?.Name ?? "KCAS user";
            await ImportService.RejectReviewAsync(row.Id, reviewedBy, ReviewReason(row.Id));
            statusMessage = $"{row.SourceTable} #{row.SourceId}: review rejected.";
            runs = await Db.LegacyImportRuns.AsNoTracking().OrderByDescending(run => run.Id).Take(20).ToListAsync();
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task StartJobAsync(Func<Task<LegacyImportJobSnapshot>> startJob)
    {
        isBusy = true;
        statusMessage = null;
        errorMessage = null;
        try
        {
            activeJob = await startJob();
            await PollActiveJobAsync(activeJob.Id);
        }
        catch (Exception ex)
        {
            errorMessage = ex.GetBaseException().Message;
            isBusy = false;
        }
    }

    private async Task PollActiveJobAsync(Guid jobId)
    {
        pollingCancellation?.Cancel();
        pollingCancellation?.Dispose();
        pollingCancellation = new CancellationTokenSource();
        var token = pollingCancellation.Token;
        try
        {
            while (!token.IsCancellationRequested)
            {
                await Task.Delay(TimeSpan.FromSeconds(1), token);
                var snapshot = ImportService.GetJob(jobId);
                if (snapshot is null)
                {
                    errorMessage = "Import job state is no longer available.";
                    isBusy = false;
                    return;
                }

                activeJob = snapshot;
                await InvokeAsync(StateHasChanged);
                if (!snapshot.IsRunning)
                {
                    isBusy = false;
                    if (snapshot.IsCompleted)
                    {
                        statusMessage = snapshot.Message;
                        if (snapshot.ResultRunId.HasValue)
                        {
                            selectedRunId = snapshot.ResultRunId.Value;
                        }
                        runs = await Db.LegacyImportRuns.AsNoTracking().OrderByDescending(run => run.Id).Take(20).ToListAsync();
                        await LoadRowsAsync();
                    }
                    else
                    {
                        errorMessage = snapshot.Message;
                    }
                    return;
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task SelectRunAsync(ChangeEventArgs args)
    {
        if (long.TryParse(args.Value?.ToString(), out var value))
        {
            selectedRunId = value;
            sourceTable = string.Empty;
            await LoadRowsAsync();
        }
    }

    private async Task FilterClassificationAsync(ChangeEventArgs args)
    {
        classification = args.Value?.ToString() ?? string.Empty;
        await LoadRowsAsync();
    }

    private async Task FilterTableAsync(ChangeEventArgs args)
    {
        sourceTable = args.Value?.ToString() ?? string.Empty;
        await LoadRowsAsync();
    }

    public ValueTask DisposeAsync()
    {
        pollingCancellation?.Cancel();
        pollingCancellation?.Dispose();
        return ValueTask.CompletedTask;
    }

    private static string Display(string? value) => value is null ? "(empty)" : value;
    private static string ShortHash(string value) => value.Length > 16 ? value[..16] + "…" : value;
    private static string FormatBytes(long bytes)
        => bytes >= 1_048_576 ? $"{bytes / 1_048_576d:N1} MB" : $"{bytes / 1024d:N1} KB";
    private string ReviewReason(long rowId) => reviewReasons.GetValueOrDefault(rowId, string.Empty);
    private string ManualValue(long rowId) => manualValues.GetValueOrDefault(rowId, string.Empty);
    private void SetReviewReason(long rowId, string? value) => reviewReasons[rowId] = value ?? string.Empty;
    private void SetManualValue(long rowId, string? value) => manualValues[rowId] = value ?? string.Empty;
}
