@page "/clients/{Id:int}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = KcasPermissions.ClientsView)]
@using Microsoft.EntityFrameworkCore
@using KCAS.Admin.Data
@inject ApplicationDbContext Db
@inject ClientOperationsService ClientOperations
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(client?.DisplayName ?? "Client")</PageTitle>

@if (client is null)
{
    <section class="empty-state">
        <h2>Client not found</h2>
        <p>The requested client could not be found in the KCAS database.</p>
    </section>
}
else
{
    <div class="page-header">
        <div>
            <p class="eyebrow">Client detail</p>
            <h1>@client.DisplayName</h1>
            <p class="text-muted mb-0">Kanaan ID: @(client.KanaanId ?? "Not captured")</p>
        </div>
        <div class="header-actions">
            <a class="btn btn-outline-secondary" href="@($"/clients/{Id}#investments")">Investments</a>
            <AuthorizeView Policy="@KcasPermissions.ClientsManage">
                <Authorized>
                    <a class="btn btn-primary" href="@($"/clients/{Id}/edit")">Edit client</a>
                </Authorized>
            </AuthorizeView>
            <a class="btn btn-outline-secondary" href="/clients">Back to clients</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info">@statusMessage</div>
    }

    <section class="detail-grid">
        <article class="detail-panel">
            <h2>Overview</h2>
            <dl>
                <dt>Title</dt>
                <dd>@Display(client.Title)</dd>
                <dt>Initials</dt>
                <dd>@Display(client.Initials)</dd>
                <dt>Full name</dt>
                <dd>@Display(client.FullName)</dd>
                <dt>Surname/entity</dt>
                <dd>@Display(client.SurnameOrEntityName)</dd>
                <dt>Language</dt>
                <dd>@Display(client.Language)</dd>
                <dt>Client folder</dt>
                <dd>@Display(client.ClientFolder)</dd>
            </dl>
        </article>

        <article class="detail-panel">
            <h2>Personal</h2>
            <dl>
                <dt>ID number</dt>
                <dd>@Display(client.PersonalProfile?.SouthAfricanIdNumber)</dd>
                <dt>Gender</dt>
                <dd>@Display(client.PersonalProfile?.Gender)</dd>
                <dt>Marital status</dt>
                <dd>@Display(client.PersonalProfile?.MaritalStatus)</dd>
                <dt>Tax number</dt>
                <dd>@Display(client.PersonalProfile?.TaxNumber)</dd>
                <dt>Tax office</dt>
                <dd>@Display(client.PersonalProfile?.TaxOffice)</dd>
                <dt>Dependents</dt>
                <dd>@Display(client.PersonalProfile?.NumberOfDependents?.ToString())</dd>
                <dt>Qualification</dt>
                <dd>@Display(client.PersonalProfile?.HighestQualification)</dd>
                <dt>Smoker</dt>
                <dd>@YesNo(client.PersonalProfile?.Smoker)</dd>
                <dt>Workday travelling %</dt>
                <dd>@Percent(client.PersonalProfile?.WorkdayTravelPercent)</dd>
            </dl>
        </article>
    </section>

    <section class="detail-panel">
        <h2>Contact</h2>
        @if (client.ContactPoints.Count == 0)
        {
            <p class="text-muted">No contact details captured.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Label</th>
                            <th>Value</th>
                            <th>Primary</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contact in client.ContactPoints.OrderBy(contact => contact.SortOrder))
                        {
                            <tr>
                                <td>@contact.ContactType</td>
                                <td>@contact.Label</td>
                                <td>@contact.Value</td>
                                <td>@(contact.IsPrimary ? "Yes" : "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-grid">
        <article class="detail-panel">
            <h2>Addresses</h2>
            @foreach (var address in client.Addresses.OrderBy(address => address.SortOrder))
            {
                <h3>@address.AddressType</h3>
                <p class="preserve-lines">@address.LinesRaw</p>
            }
            @if (client.Addresses.Count == 0)
            {
                <p class="text-muted">No addresses captured.</p>
            }
        </article>

        <article class="detail-panel">
            <h2>Family and relationships</h2>
            @if (!string.IsNullOrWhiteSpace(client.PersonalProfile?.FamilyDetailRaw))
            {
                <h3>Family detail</h3>
                <p class="preserve-lines">@client.PersonalProfile.FamilyDetailRaw</p>
            }
            @foreach (var relationship in client.Relationships.OrderBy(relationship => relationship.RelationshipType))
            {
                <h3>@relationship.RelationshipType</h3>
                <dl>
                    <dt>Name</dt>
                    <dd>@Display(relationship.Name)</dd>
                    <dt>Email</dt>
                    <dd>@Display(relationship.Email)</dd>
                    <dt>Mobile</dt>
                    <dd>@Display(relationship.MobilePhone)</dd>
                    <dt>Employer</dt>
                    <dd>@Display(relationship.Employer)</dd>
                    <dt>Occupation</dt>
                    <dd>@Display(relationship.Occupation)</dd>
                    <dt>Qualification</dt>
                    <dd>@Display(relationship.HighestQualification)</dd>
                    <dt>Gross monthly salary</dt>
                    <dd>@Money(relationship.GrossMonthlySalary)</dd>
                    <dt>Gross annual salary</dt>
                    <dd>@Money(relationship.GrossAnnualSalary)</dd>
                    <dt>Yearly bonus</dt>
                    <dd>@Money(relationship.YearlyBonus)</dd>
                    <dt>Pension fund</dt>
                    <dd>@Display(relationship.PensionFundName)</dd>
                </dl>
            }
            @if (client.Relationships.Count == 0 && string.IsNullOrWhiteSpace(client.PersonalProfile?.FamilyDetailRaw))
            {
                <p class="text-muted">No relationships captured.</p>
            }
        </article>
    </section>

    <section class="detail-panel">
        <h2>Financial</h2>
        <div class="financial-grid">
            <dl>
                <dt>Employer</dt>
                <dd>@Display(client.FinancialProfile?.Employer)</dd>
                <dt>Occupation</dt>
                <dd>@Display(client.FinancialProfile?.Occupation)</dd>
                <dt>Gross monthly salary</dt>
                <dd>@Money(client.FinancialProfile?.GrossMonthlySalary)</dd>
                <dt>Monthly expenses</dt>
                <dd>@Money(client.FinancialProfile?.MonthlyExpenses)</dd>
                <dt>Retirement age</dt>
                <dd>@Display(client.FinancialProfile?.RetirementAge?.ToString())</dd>
                <dt>Pension fund</dt>
                <dd>@Display(client.FinancialProfile?.PensionFundName)</dd>
                <dt>Employer pension amount</dt>
                <dd>@Money(client.FinancialProfile?.EmployerPensionContributionAmount)</dd>
                <dt>Employer pension %</dt>
                <dd>@Percent(client.FinancialProfile?.EmployerPensionContributionPercent)</dd>
                <dt>Minimum retirement income %</dt>
                <dd>@Percent(client.FinancialProfile?.MinimumRetirementIncomePercent)</dd>
                <dt>Expected retirement income %</dt>
                <dd>@Percent(client.FinancialProfile?.ExpectedRetirementIncomePercent)</dd>
            </dl>

            <dl>
                <dt>Capital requirement %</dt>
                <dd>@Percent(client.FinancialProfile?.CapitalRequirementPercent)</dd>
                <dt>Preservation fund lump sum %</dt>
                <dd>@Percent(client.FinancialProfile?.PreservationFundLumpSumPercent)</dd>
                <dt>Equities %</dt>
                <dd>@Percent(client.FinancialProfile?.RepresentativeEquitiesPercent)</dd>
                <dt>Alternative investments %</dt>
                <dd>@Percent(client.FinancialProfile?.RepresentativeAlternativeInvestmentsPercent)</dd>
                <dt>Fixed property %</dt>
                <dd>@Percent(client.FinancialProfile?.RepresentativeFixedPropertyPercent)</dd>
                <dt>Offshore %</dt>
                <dd>@Percent(client.FinancialProfile?.RepresentativeOffshorePercent)</dd>
                <dt>Goals</dt>
                <dd class="preserve-lines">@Display(client.FinancialProfile?.OtherGoalsRaw)</dd>
                <dt>Bank details</dt>
                <dd class="preserve-lines">@Display(client.FinancialProfile?.BankDetailRaw)</dd>
                <dt>Will details</dt>
                <dd class="preserve-lines">@Display(client.FinancialProfile?.WillDetailRaw)</dd>
                <dt>Important notes</dt>
                <dd class="preserve-lines">@Display(client.FinancialProfile?.OtherDetailsRaw)</dd>
            </dl>
        </div>
    </section>

    <section class="detail-panel">
        <h2>Representative details</h2>
        <dl class="wide-dl">
            <dt>Name of broker</dt>
            <dd>@Display(client.FinancialProfile?.RepresentativeName)</dd>
        </dl>
    </section>

    <section class="detail-panel">
        <h2>Life and disability cover</h2>
        @{
            var lifePolicies = LifeAndDisabilityPolicies;
        }
        @if (lifePolicies.Count == 0)
        {
            <p class="text-muted">No life or disability cover records available for this client.</p>
        }
        else
        {
            <div class="financial-grid">
                <dl>
                    <dt>Life cover</dt>
                    <dd>@Money(Sum(lifePolicies, policy => policy.LifeCover))</dd>
                    <dt>Disability cover</dt>
                    <dd>@Money(Sum(lifePolicies, policy => policy.DisabilityCover))</dd>
                    <dt>Dread disease cover</dt>
                    <dd>@Money(Sum(lifePolicies, policy => policy.DreadDiseaseCover))</dd>
                </dl>
                <dl>
                    <dt>Compulsory values</dt>
                    <dd>@Money(Sum(lifePolicies, policy => policy.CompulsoryContributionValue))</dd>
                    <dt>Voluntary values</dt>
                    <dd>@Money(Sum(lifePolicies, policy => policy.VoluntaryContributionValue))</dd>
                    <dt>Monthly premium</dt>
                    <dd>@Money(Sum(lifePolicies, policy => policy.MonthlyPremium))</dd>
                </dl>
            </div>

            <div class="table-responsive note-table-wrap kyc-table-wrap">
                <table class="table align-middle kyc-table">
                    <thead>
                        <tr>
                            <th>Administrator</th>
                            <th>Product</th>
                            <th>Policy no</th>
                            <th>Life</th>
                            <th>Disability</th>
                            <th>Premium</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var policy in lifePolicies)
                        {
                            <tr>
                                <td>@Display(policy.Administrator)</td>
                                <td>@Display(policy.Product)</td>
                                <td>@Display(policy.PolicyNumber)</td>
                                <td>@Money(policy.LifeCover)</td>
                                <td>@Money(policy.DisabilityCover)</td>
                                <td>@Money(policy.MonthlyPremium)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel">
        <div class="section-heading-row">
            <div>
                <h2>Current KYC policies</h2>
                <p class="section-subtitle">@client.KycPolicies.Count policy record@(client.KycPolicies.Count == 1 ? "" : "s") available</p>
            </div>
        </div>
        @if (client.KycPolicies.Count == 0)
        {
            <p class="text-muted">No KYC policy records available for this client.</p>
        }
        else
        {
            var currentPolicies = CurrentKycPolicies;
            <div class="financial-grid">
                <dl>
                    <dt>Asset allocation value</dt>
                    <dd>@Money(Sum(currentPolicies.Where(policy => !IsLifeAndDisabilityPolicy(policy)), policy => policy.Value))</dd>
                    <dt>Debt</dt>
                    <dd>@Money(Sum(currentPolicies, policy => policy.Debt))</dd>
                    <dt>Monthly income</dt>
                    <dd>@Money(Sum(currentPolicies, policy => policy.MonthlyIncome))</dd>
                </dl>
                <dl>
                    <dt>Monthly premiums</dt>
                    <dd>@Money(Sum(currentPolicies, policy => policy.MonthlyPremium))</dd>
                    <dt>Once-off premiums</dt>
                    <dd>@Money(Sum(currentPolicies, policy => policy.OnceOffPremium))</dd>
                    <dt>Included records</dt>
                    <dd>@currentPolicies.Count(policy => policy.IncludeInCalculations)</dd>
                </dl>
            </div>

            <div class="table-responsive note-table-wrap kyc-table-wrap">
                <table class="table align-middle kyc-table">
                    <thead>
                        <tr>
                            <th>Main class</th>
                            <th>Sub class</th>
                            <th>Administrator</th>
                            <th>Product</th>
                            <th>Policy no</th>
                            <th>Value</th>
                            <th>Premium</th>
                            <th>Flags</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var policy in currentPolicies)
                        {
                            <tr>
                                <td>@Display(policy.MainClassName)</td>
                                <td>@Display(policy.SubClassName)</td>
                                <td>@Display(policy.Administrator)</td>
                                <td>@Display(policy.Product)</td>
                                <td>@Display(policy.PolicyNumber)</td>
                                <td>@Money(policy.Value)</td>
                                <td>@Money(policy.MonthlyPremium)</td>
                                <td>
                                    <div class="note-badges">
                                        @if (policy.IncludeInCalculations)
                                        {
                                            <span>Included</span>
                                        }
                                        @if (policy.IsQuote)
                                        {
                                            <span>Quote</span>
                                        }
                                        @if (policy.IsRetirementAnnuity)
                                        {
                                            <span>RA</span>
                                        }
                                        @if (policy.IsPreservationFund)
                                        {
                                            <span>PF</span>
                                        }
                                        @if (policy.IsRetrenchmentPackage)
                                        {
                                            <span>RP</span>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section id="investments" class="detail-panel">
        <div class="section-heading-row">
            <div>
                <h2>Investments</h2>
                <p class="section-subtitle">@InvestmentAccounts.Count account@(InvestmentAccounts.Count == 1 ? "" : "s") and @FundValuations.Count current fund value@(FundValuations.Count == 1 ? "" : "s") available</p>
            </div>
        </div>
        @if (InvestmentAccounts.Count == 0)
        {
            <p class="text-muted">No investment account records available for this client.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Account</th>
                            <th>Administrator</th>
                            <th>Product</th>
                            <th>Fund</th>
                            <th>Dates</th>
                            <th>Current value</th>
                            <th>Transactions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in InvestmentAccounts)
                        {
                            var activeTransactions = account.Transactions.Where(transaction => !transaction.IsDeleted).ToList();
                            var latestTransaction = LatestTransaction(account);
                            var currentValuations = CurrentValuations(account).ToList();
                            var latestBalanceTransaction = LatestBalanceTransaction(account);
                            var currentValueZar = currentValuations.Count > 0 ? SumValues(currentValuations, valuation => valuation.AmountZar) : latestBalanceTransaction?.BalanceZar;
                            var currentValueForeign = currentValuations.Count > 0 ? SumValues(currentValuations, valuation => valuation.AmountForeign) : latestBalanceTransaction?.BalanceForeign;
                            var currentValueDate = currentValuations
                                .Where(valuation => valuation.ValuationDate.HasValue)
                                .OrderByDescending(valuation => valuation.ValuationDate)
                                .Select(valuation => valuation.ValuationDate)
                                .FirstOrDefault() ?? latestBalanceTransaction?.TransactionDate;
                            <tr>
                                <td>
                                    <strong>@Display(account.AccountNumber)</strong>
                                    <div class="text-muted small">Legacy account ID @account.LegacyInvestmentAccountId</div>
                                </td>
                                <td>@Display(account.Administrator)</td>
                                <td>
                                    @Display(account.ProductName)
                                    <div class="text-muted small">@Display(account.ProductType)</div>
                                </td>
                                <td>@Display(account.FundName)</td>
                                <td>
                                    <div>Started: @Date(account.InvestmentDate)</div>
                                    <div>Surrender: @Date(account.SurrenderDate)</div>
                                </td>
                                <td>
                                    <div>@Money(currentValueZar)</div>
                                    <div class="text-muted small">@Money(currentValueForeign)</div>
                                    @if (currentValueDate.HasValue)
                                    {
                                        <div class="text-muted small">
                                            @(currentValuations.Count > 0 ? "Valuation" : "History balance"): @Date(currentValueDate)
                                        </div>
                                    }
                                    @if (currentValuations.Count > 1)
                                    {
                                        <div class="text-muted small">@currentValuations.Count fund lines</div>
                                    }
                                </td>
                                <td>
                                    @activeTransactions.Count
                                    @if (latestTransaction is not null)
                                    {
                                        <div class="text-muted small">Latest: @Date(latestTransaction.TransactionDate)</div>
                                    }
                                </td>
                            </tr>
                            @if (activeTransactions.Count > 0)
                            {
                                <tr>
                                    <td colspan="7">
                                        <details>
                                            <summary>Show history</summary>
                                            <div class="table-responsive mt-2">
                                                <table class="table table-sm align-middle">
                                                    <thead>
                                                        <tr>
                                                            <th>Date</th>
                                                            <th>Description</th>
                                                            <th>Frequency</th>
                                                            <th>Investment</th>
                                                            <th>Withdrawal</th>
                                                            <th>Balance</th>
                                                            <th>Status</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var transaction in activeTransactions.OrderByDescending(transaction => transaction.TransactionDate).ThenByDescending(transaction => transaction.LegacyInvestmentHistoryId).Take(10))
                                                        {
                                                            <tr>
                                                                <td>@Date(transaction.TransactionDate)</td>
                                                                <td>@Display(transaction.Description)</td>
                                                                <td>@Display(transaction.InvestmentFrequency)</td>
                                                                <td>
                                                                    <div>@Money(transaction.InvestmentAmountZar)</div>
                                                                    <div class="text-muted small">@Money(transaction.InvestmentAmountForeign)</div>
                                                                </td>
                                                                <td>
                                                                    <div>@Money(transaction.WithdrawalAmountZar)</div>
                                                                    <div class="text-muted small">@Money(transaction.WithdrawalAmountForeign)</div>
                                                                </td>
                                                                <td>
                                                                    <div>@Money(transaction.BalanceZar)</div>
                                                                    <div class="text-muted small">@Money(transaction.BalanceForeign)</div>
                                                                </td>
                                                                <td>@(transaction.IsFinal ? "Final" : "Preliminary")</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </details>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="detail-panel">
        <div class="section-heading-row">
            <div>
                <h2>Notes</h2>
                <p class="section-subtitle">@ActiveNotes.Count note@(ActiveNotes.Count == 1 ? "" : "s") available</p>
            </div>
            <AuthorizeView Policy="@KcasPermissions.NotesManage">
                <Authorized>
                    <a class="btn btn-outline-secondary btn-sm" href="@($"/clients/{Id}/notes/new")">Add note</a>
                </Authorized>
            </AuthorizeView>
        </div>
        @if (ActiveNotes.Count == 0)
        {
            <p class="text-muted">No active notes captured for this client.</p>
        }
        else
        {
            var filteredNotes = FilteredNotes;
            var pagedNotes = PagedNotes(filteredNotes);
            <div class="notes-toolbar">
                <input class="form-control" value="@noteFilter" @oninput="FilterNotesAsync" aria-label="Filter notes" placeholder="Search notes" />
                <div class="note-count">Showing @ShowingStart(filteredNotes.Count)-@ShowingEnd(filteredNotes.Count) of @filteredNotes.Count</div>
            </div>

            @if (filteredNotes.Count == 0)
            {
                <p class="text-muted">No notes match the current filter.</p>
            }
            else
            {
                <div class="table-responsive note-table-wrap">
                    <table class="table align-middle note-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Title and details</th>
                                <th>Opened by</th>
                                <th>Status</th>
                                <AuthorizeView Policy="@KcasPermissions.NotesManage">
                                    <Authorized>
                                        <th></th>
                                    </Authorized>
                                </AuthorizeView>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var note in pagedNotes)
                            {
                                <tr class="@(note.IsDeleted ? "is-deleted" : "")">
                                    <td class="note-date">@Display(note.NoteDate?.ToString("yyyy-MM-dd"))</td>
                                    <td>
                                        <details class="note-details">
                                            <summary>@Display(note.Title)</summary>
                                            <p class="preserve-lines">@Display(note.Details)</p>
                                            <p class="note-meta">@NoteSource(note)@(string.IsNullOrWhiteSpace(note.UpdatedBy) ? "" : $" | Updated by {note.UpdatedBy}")</p>
                                        </details>
                                    </td>
                                    <td>@Display(note.OpenedBy)</td>
                                    <td>
                                        <div class="note-badges">
                                            @if (note.IsFinal)
                                            {
                                                <span>Final</span>
                                            }
                                            else
                                            {
                                                <span>Preliminary</span>
                                            }
                                            @if (note.IsDeleted)
                                            {
                                                <span>Deleted</span>
                                            }
                                        </div>
                                    </td>
                                    <AuthorizeView Policy="@KcasPermissions.NotesManage">
                                        <Authorized>
                                            <td class="text-end">
                                                <div class="row-actions">
                                                    @if (!note.IsFinal)
                                                    {
                                                        <a class="btn btn-outline-secondary btn-sm" href="@($"/clients/{Id}/notes/{note.Id}/edit")">Edit</a>
                                                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="() => FinalizeNoteAsync(note.Id)">Finalize</button>
                                                    }
                                                    <button class="btn btn-outline-danger btn-sm" type="button" @onclick="() => DeleteNoteAsync(note.Id)">Delete</button>
                                                </div>
                                            </td>
                                        </Authorized>
                                    </AuthorizeView>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (NotePageCount(filteredNotes.Count) > 1)
                {
                    <div class="notes-pager" aria-label="Notes pages">
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="PreviousNotesPage" disabled="@(notePage <= 1)">Previous</button>
                        <span>Page @notePage of @NotePageCount(filteredNotes.Count)</span>
                        <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="@(() => NextNotesPage(filteredNotes.Count))" disabled="@(notePage >= NotePageCount(filteredNotes.Count))">Next</button>
                    </div>
                }
            }
        }
    </section>

    <section class="detail-panel">
        <h2>Seed source data</h2>
        <p class="text-muted">Development seed/import payload, shown only for mapping checks before the future final import.</p>
        <details>
            <summary>Show source payload</summary>
            <pre class="legacy-json">@client.LegacySnapshots.OrderByDescending(snapshot => snapshot.ImportedAtUtc).FirstOrDefault()?.PayloadJson</pre>
        </details>
    </section>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private const int NotePageSize = 10;
    private Client? client;
    private string? noteFilter;
    private string? statusMessage;
    private int notePage = 1;

    protected override async Task OnParametersSetAsync()
    {
        noteFilter = null;
        notePage = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        client = await Db.Clients
            .AsNoTracking()
            .AsSplitQuery()
            .Include(client => client.PersonalProfile)
            .Include(client => client.FinancialProfile)
            .Include(client => client.ContactPoints)
            .Include(client => client.Addresses)
            .Include(client => client.Relationships)
            .Include(client => client.LegacySnapshots)
            .Include(client => client.Notes)
            .Include(client => client.KycPolicies)
            .Include(client => client.FundValuations)
            .Include(client => client.InvestmentAccounts)
                .ThenInclude(account => account.Transactions)
            .SingleOrDefaultAsync(client => client.Id == Id);
    }

    private List<ClientNote> ActiveNotes => client?.Notes
        .Where(note => !note.IsDeleted)
        .ToList() ?? [];

    private List<ClientKycPolicy> CurrentKycPolicies => client?.KycPolicies
        .OrderBy(policy => policy.LegacyMainClassId)
        .ThenBy(policy => policy.LegacySubClassId)
        .ThenBy(policy => policy.Administrator)
        .ThenBy(policy => policy.Product)
        .ThenBy(policy => policy.PolicyNumber)
        .ToList() ?? [];

    private List<ClientKycPolicy> LifeAndDisabilityPolicies => CurrentKycPolicies
        .Where(IsLifeAndDisabilityPolicy)
        .ToList();

    private List<ClientInvestmentAccount> InvestmentAccounts => client?.InvestmentAccounts
        .OrderByDescending(account => account.InvestmentDate)
        .ThenBy(account => account.Administrator)
        .ThenBy(account => account.AccountNumber)
        .ToList() ?? [];

    private List<ClientFundValuation> FundValuations => client?.FundValuations
        .OrderBy(valuation => valuation.InvestmentUniqueNumber)
        .ThenBy(valuation => valuation.FundName)
        .ToList() ?? [];

    private List<ClientNote> FilteredNotes
    {
        get
        {
            if (client is null)
            {
                return [];
            }

            var notes = ActiveNotes
                .OrderByDescending(note => note.NoteDate)
                .ThenByDescending(note => note.LegacyClientNoteId)
                .AsEnumerable();

            var filter = noteFilter?.Trim();
            if (!string.IsNullOrWhiteSpace(filter))
            {
                notes = notes.Where(note =>
                    Contains(note.Title, filter) ||
                    Contains(note.Details, filter) ||
                    Contains(note.OpenedBy, filter) ||
                    Contains(note.UpdatedBy, filter) ||
                    Contains(note.NoteDate?.ToString("yyyy-MM-dd"), filter));
            }

            return notes.ToList();
        }
    }

    private List<ClientNote> PagedNotes(IReadOnlyCollection<ClientNote> notes)
    {
        var pageCount = NotePageCount(notes.Count);
        if (notePage > pageCount)
        {
            notePage = pageCount;
        }

        return notes
            .Skip((notePage - 1) * NotePageSize)
            .Take(NotePageSize)
            .ToList();
    }

    private Task FilterNotesAsync(ChangeEventArgs args)
    {
        noteFilter = args.Value?.ToString();
        notePage = 1;
        return Task.CompletedTask;
    }

    private void PreviousNotesPage()
    {
        if (notePage > 1)
        {
            notePage--;
        }
    }

    private void NextNotesPage(int noteCount)
    {
        if (notePage < NotePageCount(noteCount))
        {
            notePage++;
        }
    }

    private static int NotePageCount(int noteCount) => Math.Max(1, (int)Math.Ceiling(noteCount / (double)NotePageSize));

    private int ShowingStart(int noteCount) => noteCount == 0 ? 0 : ((notePage - 1) * NotePageSize) + 1;

    private int ShowingEnd(int noteCount) => Math.Min(noteCount, notePage * NotePageSize);

    private static bool Contains(string? value, string filter) =>
        value?.Contains(filter, StringComparison.OrdinalIgnoreCase) == true;

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "Not captured" : value;

    private static string Money(decimal? value) => value is null ? "Not captured" : value.Value.ToString("C");

    private static string Percent(decimal? value) => value is null ? "Not captured" : $"{value:0.####}%";

    private static string Date(DateOnly? value) => value is null ? "Not captured" : value.Value.ToString("yyyy-MM-dd");

    private static string YesNo(bool? value) => value is null ? "Not captured" : value.Value ? "Yes" : "No";

    private static string NoteSource(ClientNote note) =>
        note.LegacyClientNoteId is null ? "KCAS note" : $"Legacy note ID {note.LegacyClientNoteId}";

    private async Task FinalizeNoteAsync(int noteId)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        await ClientOperations.FinalizeNoteAsync(Id, noteId, authState.User.Identity?.Name);
        statusMessage = "Note finalized.";
        await LoadAsync();
    }

    private async Task DeleteNoteAsync(int noteId)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        await ClientOperations.DeleteNoteAsync(Id, noteId, authState.User.Identity?.Name);
        statusMessage = "Note deleted.";
        await LoadAsync();
    }

    private static bool IsLifeAndDisabilityPolicy(ClientKycPolicy policy) =>
        policy.LegacySubClassId == 29 ||
        string.Equals(policy.SubClassName, "Life and Disability Cover", StringComparison.OrdinalIgnoreCase);

    private static ClientInvestmentTransaction? LatestTransaction(ClientInvestmentAccount account) =>
        account.Transactions
            .Where(transaction => !transaction.IsDeleted)
            .OrderByDescending(transaction => transaction.TransactionDate)
            .ThenByDescending(transaction => transaction.LegacyInvestmentHistoryId)
            .FirstOrDefault();

    private static ClientInvestmentTransaction? LatestBalanceTransaction(ClientInvestmentAccount account) =>
        account.Transactions
            .Where(transaction =>
                !transaction.IsDeleted &&
                ((transaction.BalanceZar.HasValue && transaction.BalanceZar.Value != 0) ||
                 (transaction.BalanceForeign.HasValue && transaction.BalanceForeign.Value != 0)))
            .OrderByDescending(transaction => transaction.TransactionDate)
            .ThenByDescending(transaction => transaction.LegacyInvestmentHistoryId)
            .FirstOrDefault();

    private IEnumerable<ClientFundValuation> CurrentValuations(ClientInvestmentAccount account)
    {
        var accountNumber = NormalizeAccountNumber(account.AccountNumber);
        if (accountNumber is null)
        {
            return [];
        }

        var matches = FundValuations
            .Where(valuation => string.Equals(NormalizeAccountNumber(valuation.InvestmentUniqueNumber), accountNumber, StringComparison.OrdinalIgnoreCase))
            .ToList();

        var administrator = NormalizeLookup(account.Administrator);
        if (administrator is null)
        {
            return matches;
        }

        var administratorMatches = matches
            .Where(valuation => AdministratorsMatch(administrator, NormalizeLookup(valuation.Administrator)))
            .ToList();

        return administratorMatches.Count > 0 ? administratorMatches : matches;
    }

    private static bool AdministratorsMatch(string accountAdministrator, string? valuationAdministrator) =>
        valuationAdministrator is not null &&
        (string.Equals(accountAdministrator, valuationAdministrator, StringComparison.OrdinalIgnoreCase) ||
         accountAdministrator.Contains(valuationAdministrator, StringComparison.OrdinalIgnoreCase) ||
         valuationAdministrator.Contains(accountAdministrator, StringComparison.OrdinalIgnoreCase));

    private static string? NormalizeAccountNumber(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? null
            : new string(value.Where(char.IsLetterOrDigit).ToArray()).ToUpperInvariant();

    private static string? NormalizeLookup(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static decimal? SumValues<T>(IEnumerable<T> items, Func<T, decimal?> selector)
    {
        var values = items.Select(selector).Where(value => value.HasValue).Select(value => value!.Value).ToList();
        return values.Count == 0 ? null : values.Sum();
    }

    private static decimal? Sum(IEnumerable<ClientKycPolicy> policies, Func<ClientKycPolicy, decimal?> selector)
    {
        var values = policies.Select(selector).Where(value => value.HasValue).Select(value => value!.Value).ToList();
        return values.Count == 0 ? null : values.Sum();
    }
}
